{
  "name": "winr-web-sdk",
  "version": "1.0.0",
  "description": "Web SDK for WINR sweepstakes platform",
  "main": "dist/winr-sdk.umd.js",
  "module": "dist/winr-sdk.esm.js",
  "types": "dist/winr-sdk.d.ts",
  "exports": {
    ".": {
      "import": "./dist/winr-sdk.esm.js",
      "require": "./dist/winr-sdk.umd.js",
      "types": "./dist/winr-sdk.d.ts"
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "npm run clean && npm run type-check && rollup -c",
    "build:dev": "rollup -c --environment NODE_ENV:development",
    "build:prod": "rollup -c --environment NODE_ENV:production",
    "clean": "rm -rf dist",
    "type-check": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src --ext .ts",
    "lint:fix": "eslint src --ext .ts --fix",
    "prepare": "npm run build"
  },
  "keywords": [
    "winr",
    "sweepstakes",
    "engagement",
    "sdk",
    "web",
    "javascript",
    "typescript"
  ],
  "author": "WINR Team",
  "license": "MIT",
  "dependencies": {},
  "devDependencies": {
    "@rollup/plugin-commonjs": "^25.0.7",
    "@rollup/plugin-node-resolve": "^15.2.3",
    "@rollup/plugin-terser": "^0.4.4",
    "@rollup/plugin-typescript": "^11.1.6",
    "@types/node": "^20.11.19",
    "@typescript-eslint/eslint-plugin": "^7.0.2",
    "@typescript-eslint/parser": "^7.0.2",
    "eslint": "^8.56.0",
    "rollup": "^4.12.0",
    "rollup-plugin-dts": "^6.1.0",
    "tslib": "^2.6.2",
    "typescript": "^5.3.3",
    "vitest": "^1.3.1",
    "@vitest/coverage-v8": "^1.3.1"
  },
  "engines": {
    "node": ">=16"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/winr-sdk/winr-web-sdk.git"
  },
  "bugs": {
    "url": "https://github.com/winr-sdk/winr-web-sdk/issues"
  },
  "homepage": "https://github.com/winr-sdk/winr-web-sdk#readme"
}